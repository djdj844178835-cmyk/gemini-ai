# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# THIRD_PARTY_API_KEY: Your purchased API key
THIRD_PARTY_API_KEY="sk-vU5dTGQDuUVDxoqI2E8tYOyQfG5a8tpEWEoe3csyQ9VNMmVB"

# THIRD_PARTY_API_BASE_URL: The proxy endpoint URL (e.g., https://api.example.com/v1)
THIRD_PARTY_API_BASE_URL="https://api.openai.com/v1"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
